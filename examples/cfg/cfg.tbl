--[[

    Note:

        - You should use a texteditor with Lua syntax highlighting e.g.: Notepad++

        - Please go through these settings, conscientiously line by line. they are the basic settings
          of the hub and very important. It will take about 15 minutes.
        - In the settings you will find boolean values. The possibilities are: true (YES) / false (NO)

]]

return { -- the settings are a lua table, do not tough this!

    ---------------------------------------------------------------------------------------------------------------------------------
    --// Basic Settings

    language = "en",  -- your language version (string); available: en = english / de = german  |  check project website for additional languages: https://github.com/luadch/translations)

    hub_name = "Luadch-NG Hub",  -- name of your hub (string)
    hub_description = "your hub description",  -- hub default description/topic (string)

    hub_hostaddress = "your.host.addy.org",  -- your hostadress (string)

    -- TLS-only by default since v3.1.6 (#77). On first boot the hub
    -- auto-generates a self-signed P-256 cert at certs/servercert.pem
    -- and logs the keyprint for the adcs:// URL. To enable plain ADC
    -- alongside, add port numbers to tcp_ports / tcp_ports_ipv6.
    tcp_ports = { },  -- listen on these ports for normal tcp connections (e.g.: adc://<address>:<port>) (integer array); empty {} = TLS-only
    ssl_ports = { 5001 },  -- listen on these ports for ssl tcp connections (e.g.: adcs://<address>:<port>) (integer array); to use more than one port use: { port, port, port },
    tcp_ports_ipv6 = { },  -- listen on these ports for normal tcp IPv6 connections (e.g.: adc://<address>:<port>) (integer array); empty {} = TLS-only
    ssl_ports_ipv6 = { 5001 },  -- listen on these ports for ssl tcp IPv6 connections (e.g.: adcs://<address>:<port>) (integer array); to use more than one port use: { port, port, port }, -- same port as ssl_ports works since v3.2.x (HTTP/80-style dual-stack)

    hub_listen = { "*" },  -- ADC listener bind address(es): "*" = all interfaces (default); e.g. { "127.0.0.1" } = loopback only. Applies to BOTH IPv4 + IPv6 listeners (a v4-only address yields no IPv6 listener)

    -- HBRI (Hub-Bridged Reverse Initiation, #214 / #291 / #286). A dual-stack client advertises a secondary IP family (a concrete address OR the auto-detect placeholder I6:: / I40.0.0.0), but the hub can only authenticate the family matching the connecting TCP source; the OTHER (secondary) family is ALWAYS stripped before broadcast (DDoS-amplification safety). With HBRI enabled the hub asks a supporting client to prove its secondary over a second-family side-channel and, on success, restores the verified secondary to the broadcast INF - the committed address is always the side-channel's authenticated source (getpeername), never a client-stated value. Works at login AND when a secondary first appears in a later INF update (#286).
    hbri_enabled = false,  -- boolean. Default OFF. Effective ONLY when the hub has a listener on BOTH families (tcp_ports/ssl_ports AND tcp_ports_ipv6/ssl_ports_ipv6 - the side-channel rides that port's transport, plain or TLS/autossl) AND both advertise addresses below are set; otherwise the secondary just stays stripped.
    hbri_advertise_v4 = "",  -- the hub's PUBLIC IPv4 address an HBRI client connects to for the side-channel. Required when hbri_enabled (the hub cannot reliably auto-detect its routable address behind NAT / a "::" bind). Empty = do not advertise / initiate. No whitespace.
    hbri_advertise_v6 = "",  -- the hub's PUBLIC IPv6 address for the side-channel (same rules as hbri_advertise_v4).
    hbri_timeout = 5,  -- seconds (1..60) the hub waits for the side-channel validation before letting the client in without the secondary. adchpp default is 5.

    http_port = false,  -- local HTTP API (#82): false = OFF (default, no socket bound); a number = bind hardened HTTP framer on http_bind_addr:<n> (default 127.0.0.1; use a reverse proxy for non-loopback). Phase 1b ships /health (no auth) + /v1/endpoints (token-auth, scope-filtered route discovery). Plugin-extensible: bundled and third-party plugins register their endpoints via hub.http_register on onStart. See docs/HTTP_API.md.
    http_bind_addr = "127.0.0.1",  -- HTTP API bind address. Default "127.0.0.1" (loopback) is the security premise for shipping the API without transport-layer TLS/auth. Set to "0.0.0.0" (or "::") ONLY when running the hub in a container and the API needs to be reachable from sibling containers (WebUI, reverse proxy) via a private Docker network whose port is NOT published to the host. Never bind to a public interface - put a reverse proxy in front. Bare-metal operators leave this at the default. Init-time only: changes via `+reload` do NOT re-bind the listener; a full hub restart is required (same as `http_port`). Validator rejects whitespace + control bytes. See docs/HTTP_API.md §2.
    http_api_tokens = { },  -- bearer token table (#82). Map form: { ["<opaque-token>"] = { scope = "read"|"admin", comment = "<free-form>" } }. Empty {} (default) keeps the HTTP listener DOWN even when http_port is set (#231): the hub writes a sample token to cfg/api_token.first (chmod 600) on first boot, but the API is NOT reachable until the operator copies the value into this table and restarts (or +reload). Recommended >= 32 bytes of CSPRNG entropy, encoded as base32 (matches the sample format) or base64. Tokens reload on +reload; remove a row to revoke immediately. See docs/HTTP_API.md §4.7 for the activation flow.
    http_api_log_reads = false,  -- audit-log GET requests too (boolean). Default false (would spam api_audit.log under WebUI polling). Enable for forensic sessions; writes always logged regardless.
    http_api_rate_read = 120,  -- per-token rate-limit for read-scope tokens, requests per minute (#82 §6.3). Default 120 - WebUI polling lives here. Bucket keyed on a per-token internal id, not IP - one runaway client cannot starve a parallel WebUI session using a different token.
    http_api_rate_admin = 60,  -- per-token rate-limit for admin-scope tokens, requests per minute (#82 §6.3). Default 60. X-Confirm endpoints (/v1/reload, /v1/restart, /v1/shutdown, DELETE /v1/registered/{nick}) are exempt so operator recovery actions always succeed.
    http_api_burst = 10,  -- shared burst capacity for both http_api_rate_* buckets (integer). Default 10. Higher = more tolerant of short request spikes; lower = stricter shaping.
    http_api_authfail_prefix_rate = 10,  -- per-token-prefix failed-auth bucket, fails per minute (#82 §4.8). Default 10. Keyed on the first 4 chars of the Bearer payload; bound on walk-the-token-space brute force without affecting legitimate WebUI restarts.
    http_api_authfail_prefix_burst = 5,  -- burst capacity for the per-prefix failed-auth bucket (integer). Default 5.
    http_api_idempotency_max_entries = 1024,  -- cap on the X-Idempotency-Key cache (#82 §6.2). Cache is bounded by BOTH the 5-min TTL AND this entry count (FIFO eviction when cap hit). Cleared on +reload because cached handler closures may no longer exist.
    log_api_audit = true,  -- write api_audit.log for HTTP API writes (boolean). Should be true; one line per non-GET request with timestamp + method + path + status + token-label + source IP + idempotency key + request ID + body summary. Recommend enabled for compliance / incident review.

    zlif_enabled = false,  -- ADC-EXT ZLIF stream compression (#147 T3.2): false = OFF (default, hub does not advertise ADZLIF, no compression). true = hub advertises ADZLIF in SUP, initiates IZON on plain-ADC connections whose client also advertised ADZLIF, decompresses inbound on client's ZON. Saves bandwidth on busy hubs; costs CPU per connection.
    zlif_over_tls = false,  -- NOT RECOMMENDED on ADCS / TLS hubs (boolean). Default OFF: TLS already encrypts the wire, and stacking compression UNDER TLS opens a theoretical CRIME-class chosen-plaintext-length leak surface (eavesdropper-only; see docs/SECURITY.md §6). The mitigation cost is one cfg flag; the bandwidth saving on already-encrypted connections is usually not worth the residual risk. Only set true on busy hubs where you have specifically weighed the trade-off. Plain ADC connections see ZLIF regardless.

    blom_enabled = false,  -- ADC-EXT BLOM hash-search routing (#147 T2.2): false = OFF (default). true = hub advertises ADBLOM, requests a per-user bloom filter via HGET on NORMAL-state entry, and routes HASH-search SCH (those carrying TR/TTH) only to clients whose filter could match. KEYWORD searches (AN/NO/EX/TY/etc.) always broadcast unchanged regardless of this flag - the filter cannot match plain-text keywords by design. Combined with `zlif_enabled`: the hub splices the counted-binary capture between inflate and the ADC-line framer (#192) so the filter is built from decompressed payload bytes.
    blom_k = 6,  -- number of hash functions / bits set per inserted TTH (integer 1..24). With k=6 and h=16 the slicing uses 96 of the 192 TTH bits - safely under the spec ceiling (k*h <= 192).
    blom_h = 16,  -- bits per slice index (integer, must be a positive multiple of 8 in [8, 64]). 2^h must exceed blom_m, so h=16 (2^16 = 65536) covers any blom_m up to 32768. Raise h together with m for larger shares.
    blom_m = 32768,  -- filter size in BITS (integer multiple of 64). Default 32768 = 4 KiB filter per user. Raise to ~30 * (expected files per share) for a < 5% false-positive rate; e.g. blom_m = 1048576 (128 KiB filter) for a 30k-file share. Larger m costs per-user RAM on the hub.

    use_ssl = true,  -- use ssl (boolean); you have to make a cert for adcs!; use "certs/make_cert.bat/.sh" or "Luadch-NG Certmanager"

    hub_website = "https://yourwebsite.org",  -- your website (string)
    hub_network = "your hubnetwork name",  -- your hubnetwork name (string)
    hub_email = "hub@mail.com", -- your hub email (string)
    hub_owner = "you",  -- hubowner (string)

    hub_bot = "[BOT]HubSecurity",  -- name of hub bot (string)
    hub_bot_desc = "[ BOT ] Hub Security",  -- description of hub bot (string)
    hub_bot_email = false, -- show hub_email as email in userlist (boolean)

    reg_only = true,  -- reg only hub (boolean)

    max_users = 2000,  -- max users (integer)

    max_bad_password = 3,  -- max bad password on connect (integer)
    bad_pass_timeout = 600,  -- tempban in seconds if max bad password was exceeded (integer)
    min_password_length = 10,  -- minimum length of the password (integer)
    max_password_length = 30,  -- maximum length of the password (integer)

    -- kick on login when client-claimed I4/I6 differs from TCP source IP. (boolean)
    -- Default false: the hub silently overrides the claim with the verified TCP source
    -- before broadcasting (spoofing prevented by #214 Gap 2), so VPN / CGNAT / dual-stack
    -- users with mildly off claims stay connected. Set true to instead kick mismatched
    -- clients with an actionable hint (useful for hubs with tightly-configured userbases).
    kill_wrong_ips = false,

    -- ====================================================================
    -- !!! IMPORTANT - SET BEFORE PUTTING REAL USERS INTO USER.TBL !!!
    --
    -- Path to the master.key that decrypts cfg/user.tbl (Phase 7f, AES-256-GCM).
    --
    -- Empty default (= cfg/master.key) is for first-boot convenience and
    -- backwards compatibility ONLY. With the default, anyone who steals a
    -- routine `tar czf backup.tar.gz cfg/` gets BOTH the encrypted user db
    -- AND its decryption key, and can decrypt offline. The encryption then
    -- provides zero protection.
    --
    -- For production, set an absolute path OUTSIDE the install directory,
    -- treat the file like your TLS private key (chmod 600, separate
    -- backup destination), then exclude that path from the cfg/ backup.
    --
    -- Examples:
    --     master_key_path = "/etc/luadch/master.key"            -- POSIX
    --     master_key_path = "C:/ProgramData/luadch/master.key"  -- Windows
    --
    -- See docs/SECURITY.md §3 for the threat model.
    -- ====================================================================
    master_key_path = "",

    -- ====================================================================
    -- Encrypt cfg/user.tbl at rest? (#128)
    --
    -- true  = AES-256-GCM blob with LDC1 magic header (Phase 7f default).
    --         Plaintext-equivalent passwords never hit the disk.
    -- false = plaintext Lua source. Use case: home / single-user hub
    --         where disk-level confidentiality is not part of the threat
    --         model and operator tooling needs direct read access.
    --
    -- Migration is automatic in both directions: the toggle changes what
    -- the NEXT save writes; existing files are auto-detected via the LDC1
    -- magic prefix. master.key is loaded if present (for legacy decrypt)
    -- but only auto-generated when encrypt_usertbl = true.
    --
    -- Disabling means user passwords are readable by anyone with file
    -- access to cfg/user.tbl - keep chmod 600 (POSIX) and your backup
    -- hygiene tight. See docs/SECURITY.md §3 for the trade-off.
    -- ====================================================================
    encrypt_usertbl = true,

    min_nickname_length = 3,  -- minimum length of the nickname (integer)
    max_nickname_length = 30,  -- maximum length of the nickname (integer)

    key_level = 50,  -- min level to get a key (integer); match this with your scripts

    debug = false,  -- displays events, errors or script messages on screen (boolean); warning: slows the hub down when active!
    log_errors = true,  -- save errors in a log file (boolean); should be true
    log_events = false,  -- saves debug messages (boolean); warning: slows the hub down when active!; generates a big log file!
    log_scripts = false,  -- saves script messages (boolean); warning: generate a big log file!

    ---------------------------------------------------------------------------------------------------------------------------------
    --// etc_usercommands.lua settings | this script exports a module to reg usercommands (rightclick-menu)

    etc_usercommands_toplevelmenu = "Luadch-NG Menu",  -- name of the toplevel rightclick menu (string)

    ---------------------------------------------------------------------------------------------------------------------------------
    --// Your hub levels with level names | match it with all of your script permissions! (array of strings)

    levels = {

        [ 0 ] = "UNREG",
        [ 10 ] = "GUEST",
        [ 20 ] = "REG",
        [ 30 ] = "VIP",
        [ 40 ] = "SVIP",
        [ 50 ] = "SERVER",
        [ 55 ] = "SBOT",
        [ 60 ] = "OPERATOR",
        [ 70 ] = "SUPERVISOR",
        [ 80 ] = "ADMIN",
        [ 100 ] = "HUBOWNER",
    },

    ---------------------------------------------------------------------------------------------------------------------------------
    --// usr_nick_prefix.lua settings | this script adds a prefix to the nick of a user

    usr_nick_prefix_activate = true,  -- activate this script? (boolean)

    usr_nick_prefix_prefix_table = {

        -- [ user_level ] = level_prefix (no whitespaces!) (array of strings)

        [ 0 ] = "[UNREG]",
        [ 10 ] = "[GUEST]",
        [ 20 ] = "[REG]",
        [ 30 ] = "[VIP]",
        [ 40 ] = "[SVIP]",
        [ 50 ] = "[SERVER]",
        [ 55 ] = "[SBOT]",
        [ 60 ] = "[OPERATOR]",
        [ 70 ] = "[SUPERVISOR]",
        [ 80 ] = "[ADMIN]",
        [ 100 ] = "[HUBOWNER]",
    },

    usr_nick_prefix_permission = {  -- choose which levels should be tagged (array of boolean)

        [ 0 ] = true,  -- unreg
        [ 10 ] = true,  -- guest
        [ 20 ] = true,  -- reg
        [ 30 ] = true,  -- vip
        [ 40 ] = true,  -- svip
        [ 50 ] = true,  -- server
        [ 55 ] = true,  -- sbot
        [ 60 ] = true,  -- operator
        [ 70 ] = true,  -- supervisor
        [ 80 ] = true,  -- admin
        [ 100 ] = true,  -- hubowner
    },

    usr_nick_prefix_report = true,  -- on a prefix-kick fire etc_report.send with nick+IP+reason (boolean)
    usr_nick_prefix_report_hubbot = false,  -- send the report as a hubbot PM (boolean)
    usr_nick_prefix_report_opchat = true,  -- send the report into op-chat (boolean)
    usr_nick_prefix_llevel = 60,  -- min level for the hubbot-PM report (integer)

    ---------------------------------------------------------------------------------------------------------------------------------
    --// usr_desc_prefix.lua settings | this script adds a prefix to the description of a user

    usr_desc_prefix_activate = true,  -- activate this script? (boolean)

    usr_desc_prefix_prefix_table = {

        -- [ user_level ] = level_prefix (array of strings)

        [ 0 ] = "[ UNREG ] ",
        [ 10 ] = "[ GUEST ] ",
        [ 20 ] = "[ REG ] ",
        [ 30 ] = "[ VIP ] ",
        [ 40 ] = "[ SVIP ] ",
        [ 50 ] = "[ SERVER ] ",
        [ 55 ] = "[ SBOT ] ",
        [ 60 ] = "[ OPERATOR ] ",
        [ 70 ] = "[ SUPERVISOR ] ",
        [ 80 ] = "[ ADMIN ] ",
        [ 100 ] = "[ HUBOWNER ] ",
    },

    usr_desc_prefix_permission = {  -- choose which levels should be tagged (array of boolean)

        [ 0 ] = true,  -- unreg
        [ 10 ] = true,  -- guest
        [ 20 ] = true,  -- reg
        [ 30 ] = true,  -- vip
        [ 40 ] = true,  -- svip
        [ 50 ] = true,  -- server
        [ 55 ] = true,  -- sbot
        [ 60 ] = true,  -- operator
        [ 70 ] = true,  -- supervisor
        [ 80 ] = true,  -- admin
        [ 100 ] = true,  -- hubowner
    },

    ---------------------------------------------------------------------------------------------------------------------------------
    --// bot_regchat.lua settings | this script regs an reg chat

    bot_regchat_activate = true,  -- activate this script? (boolean)

    bot_regchat_nick = "[CHAT]RegChat",  -- reg chat name? (string)
    bot_regchat_desc = "[ CHAT ] chatroom for reg users",  -- reg chat description? (string)

    bot_regchat_history = true,  -- use chat history? (boolean)
    bot_regchat_max_entrys = 300,  -- max posts to save in database? (integer)
    bot_regchat_oplevel = 60,  -- minlevel to reset the history (integer)

    bot_regchat_permission = {  -- who is allowed to join the reg chat? (array of boolean)

        [ 0 ] = false,  -- unreg
        [ 10 ] = false,  -- guest
        [ 20 ] = true,  -- reg
        [ 30 ] = true,  -- vip
        [ 40 ] = true,  -- svip
        [ 50 ] = true,  -- server
        [ 55 ] = false,  -- sbot
